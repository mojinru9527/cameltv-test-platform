+    ) or 0
+    result = embed_pending_chunks_in_new_session(pid)  # зӢ¬з«Ӣ SessionгҖҒеҲҶжү№гҖҒе№Ӯзӯү
+    _audit(req, current, db, "knowledge:reembed", f"project#{pid}", str(result))
