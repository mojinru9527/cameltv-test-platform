+    setLoading(true)
+    setSearched(true)
+    searchKnowledge({ query: q, mode: mode as 'hybrid' | 'keyword' | 'vector', top_k: 10 })
+      .then((res) => setResults(res || []))
+      .catch((e) => {
+        setResults([])
