+      })
+      .finally(() => setLoading(false))
+  }
+
+  const doReembed = () => {
+    setReembedding(true)
+    reembedKnowledge()
+      .then((r) => toast.success(`еӣһеЎ«е®ҢжҲҗпјҡе…ұ ${r.total} жқЎпјҢе·ІеөҢе…Ҙ ${r.embedded}пјҢи·іиҝҮ ${r.skipped}`))
