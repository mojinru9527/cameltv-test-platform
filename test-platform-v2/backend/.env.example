# ============================================================
# CamelTv 测试平台 v2 — 环境变量配置模板
# 复制为 .env 并填入真实值（.env 已加入 .gitignore）
# ============================================================

# ── 运行模式 ──
# development: 开发模式，允许弱默认值（仅供本地）
# production:  生产模式，强制校验密钥/密码必填
ENVIRONMENT=development

# ── 应用 ──
APP_NAME=CamelTv Test Platform API
APP_VERSION=2.1.0

# ── 安全（生产必填）──────────
# SECRET_KEY: JWT 签名密钥，生产环境务必使用强随机字符串
#   生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 数据库 ──────────────────
# SQLite (默认) : sqlite:///./data/platform.db
# PostgreSQL    : postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./data/platform.db

# ── CORS ───────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── 默认管理员（生产必改）────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── AI / LLM（DeepSeek 兼容 OpenAI 协议）────
AI_ENABLED=true
AI_API_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=8192
AI_TEMPERATURE=0.3

# ── ELK / 日志排障 ─────────
ELK_BASE_URL=
ELK_INDEX=*

# ── 蓝湖提取（可选）─────────
# 优先使用 COOKIE（手动从浏览器复制）；若 Cookie 过期可配置账密自动登录
LANHU_COOKIE=
LANHU_USERNAME=
LANHU_PASSWORD=

# ── 文件路径（可选，留空=自动检测）────
# WORKSPACE_ROOT=F:/CamelTv
# SKILL_DIR=F:/CamelTv/.claude/skills/test-case-design
# DATA_DIR=F:/CamelTv/test-platform-v2/backend/data

# ── 调度与通知（规划）────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=
