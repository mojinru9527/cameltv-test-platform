# CamelTv 测试平台 v2 — 安全部署配置模板
# 复制为 .env 并填写真实值；.env 已被 Git 忽略，禁止提交。

ENVIRONMENT=development

# 必填：JWT 密钥与首批账号密码。所有值使用独立强随机字符串。
SECRET_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
TESTER_USERNAME=tester
TESTER_PASSWORD=

# 前端端口
FRONTEND_PORT=80

# CORS 允许的来源（逗号分隔）
ALLOWED_ORIGINS=http://localhost

# ── PostgreSQL（可选，默认使用 SQLite）────
# DATABASE_URL=postgresql://cameltv:<通过密码管理器填写>@postgres:5432/cameltv
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ── PostgreSQL 服务凭据 ──
POSTGRES_USER=cameltv
POSTGRES_PASSWORD=
POSTGRES_DB=cameltv

# ELK/Kibana 配置（可选，用于 traceId 链路追踪）
ELK_BASE_URL=
ELK_INDEX=*

# AI 功能可选；未配置 Key 时保持关闭。RAG 本地向量检索不依赖外部 AI Key。
AI_ENABLED=false
AI_API_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=8192
AI_TEMPERATURE=0.3

# 蓝湖可选；Cookie、账号和密码都只写在本地 .env。
LANHU_COOKIE=
LANHU_USERNAME=
LANHU_PASSWORD=

# RAG / Wiki / 证据采集
KNOWLEDGE_INGEST_ENABLED=true
RAG_ENABLED=true
KNOWLEDGE_GRAPH_ENABLED=true
WIKI_ENABLED=true
WIKI_AUTO_INGEST_ENABLED=true
WIKI_DIFF_ENABLED=true
KNOWLEDGE_INGEST_PRODUCTION_DATA=false
LANHU_MCP_ENABLED=true
EMBEDDING_CACHE_DIR=/data/models/fastembed
LANHU_EVIDENCE_ENABLED=true
LANHU_OCR_PROVIDER=local

# SMTP 可选；也可以在 Web 通知中心使用钉钉/飞书/企业微信 Webhook。
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
