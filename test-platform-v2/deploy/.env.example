# CamelTv 测试平台 v2 — 部署配置
# 复制为 .env 并修改实际值:  cp .env.example .env

# JWT 密钥（生产务必设置强随机字符串）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# 前端端口
FRONTEND_PORT=80

# CORS 允许的来源（逗号分隔）
ALLOWED_ORIGINS=*

# ── PostgreSQL（可选，默认使用 SQLite）────
# DATABASE_URL=postgresql://cameltv:cameltv123@postgres:5432/cameltv
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ── PostgreSQL 服务凭据 ──
# POSTGRES_USER=cameltv
# POSTGRES_PASSWORD=cameltv123
# POSTGRES_DB=cameltv

# ELK/Kibana 配置（可选，用于 traceId 链路追踪）
ELK_BASE_URL=
ELK_INDEX=*
