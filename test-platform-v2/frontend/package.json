{
  "name": "cameltv-test-frontend",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "tsc -b && vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "npx @axe-core/cli --stdout http://localhost:5173 || echo 'Run: npx @axe-core/cli --stdout <url>'",
    "lighthouse:a11y": "lhci autorun --collect.url=http://localhost:5173 --collect.numberOfRuns=1 --assert.assertions.preset=lighthouse:recommended --assert.assertions.accessibility=90 || echo 'Ensure the dev server is running on port 5173'",
    "gen:api": "openapi-typescript http://localhost:8000/openapi.json -o src/types/api.d.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.15",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toggle": "^1.1.15",
    "@radix-ui/react-toggle-group": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tanstack/react-table": "^8.20.5",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.468.0",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.5",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^6.27.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "vis-data": "^8.0.4",
    "vis-network": "^10.1.0",
    "zod": "^3.24.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.10.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.16.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-dropzone": "^5.1.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.4.2",
    "postcss": "^8.4.49",
    "serve": "^14.2.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.0"
  }
}
