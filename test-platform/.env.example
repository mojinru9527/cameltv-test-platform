# ============================================================
# 敏感凭据 — 复制为 .env 并填写真实值（.env 已被 gitignore）
# YAML 用 ${VAR} 插值引用这里的变量，避免明文入库
# ============================================================

# --- 上游代理（访问正式环境需要 vpn07 tun + 全局流量）---
UPSTREAM_PROXY=
VPN_TUN_ADDR=        # vpn07 tun 地址 host:port，用于前置连通性检查

# --- CamelTv / 测试环境 ---
CAMELTV_TEST_AUTH_TOKEN=
CAMELTV_TEST_DB_USER=
CAMELTV_TEST_DB_PWD=
CAMELTV_TEST_REDIS_PWD=
CAMELTV_TEST_MQ_USER=
CAMELTV_TEST_MQ_PWD=

# --- CamelTv / 正式环境 ---
CAMELTV_PROD_AUTH_TOKEN=
CAMELTV_PROD_DB_USER=
CAMELTV_PROD_DB_PWD=
CAMELTV_PROD_REDIS_PWD=
CAMELTV_PROD_MQ_USER=
CAMELTV_PROD_MQ_PWD=

# --- 日志聚合 ELK（内网）---
# Kibana: https://elk.elelive.cn/app/kibana  账号: eleuser
# 备用日志检索: http://logsearch.elelive.net/  （同账号密码，均需内网访问）
ELASTIC_URL=
ELASTIC_API_KEY=
KIBANA_URL=https://elk.elelive.cn/app/kibana
ELK_USER=eleuser
ELK_PASSWORD=                    # 填入真实密码（勿提交 .env，已被 gitignore）

# --- midscene AI 模型 ---
MIDSCENE_MODEL_BACKEND=qwen-vl
MIDSCENE_MODEL_API_KEY=
