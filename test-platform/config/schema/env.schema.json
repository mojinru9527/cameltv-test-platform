{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Environment config",
  "type": "object",
  "required": ["base_url"],
  "properties": {
    "name": {"type": "string"},
    "kind": {"enum": ["prod", "test"]},
    "base_url": {"type": "string", "format": "uri"},
    "proxy": {"type": "string"},
    "auth_token": {"type": "string"},
    "expect_version": {"type": "string"},
    "dbs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "dsn"],
        "properties": {
          "name": {"type": "string"},
          "type": {"enum": ["mysql", "postgres"]},
          "dsn": {"type": "string"},
          "check": {"enum": ["ping", "rw"]}
        }
      }
    },
    "redis": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["host"],
        "properties": {
          "name": {"type": "string"},
          "host": {"type": "string"},
          "port": {"type": "integer"},
          "password": {"type": "string"},
          "db": {"type": "integer"}
        }
      }
    },
    "mqs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": {"type": "string"},
          "type": {"enum": ["rabbitmq", "kafka"]},
          "url": {"type": "string"}
        }
      }
    },
    "https": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": {"type": "string"},
          "url": {"type": "string"},
          "expect_version": {"type": "string"}
        }
      }
    },
    "preset_data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["db", "table"],
        "properties": {
          "db": {"type": "string"},
          "table": {"type": "string"},
          "min_rows": {"type": "integer"},
          "where": {"type": "string"}
        }
      }
    }
  }
}
